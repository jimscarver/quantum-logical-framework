import Mathlib
import QLF_CohomologyRing

/-!
# QLF_CohomologyAlgebra ‚Äî `cl` as a ‚Ñö-algebra homomorphism; the algebraic classes as a `Subalgebra ‚Ñö`

`QLF_CohomologyLinear` made the algebraic classes a `Submodule ‚Ñö` (closed under ‚Ñö-scaling and addition).
But cohomology is a **ring** (cup product), and the algebraic classes are closed under it too ‚Äî they form a
**subalgebra**. This capstone proves exactly that, by upgrading the cycle class map to a ‚Ñö-algebra
homomorphism.

The cohomology ring as a ‚Ñö-algebra is the **monoid algebra** `CohA = AddMonoidAlgebra ‚Ñö Coh` (the free
‚Ñö-algebra on the cohomology monomials `Coh = Multiset ‚Ñï`, with multiplication = convolution = cup product,
since `Coh`'s monoid law is union). On it:

* **`cl` is a ‚Ñö-algebra homomorphism.** `clA_mul` ‚Äî `clA c ¬∑ clA d = clA (c ‚äó d)` (the cycle class map sends
  the intersection product to the cup product, now as honest *ring* multiplication via
  `AddMonoidAlgebra.single_mul_single`); `clA_one` ‚Äî `clA unitCycle = 1` (the unit cycle ‚Ü¶ the ring unit).
  So `cl` respects *all* the structure: addition (from the ‚Ñö-linear layer), the grading
  (`QLF_CohomologyRing`), and now multiplication.
* **The algebraic classes are a `Subalgebra ‚Ñö`.** `algebraicA = Algebra.adjoin ‚Ñö (range clA)` ‚Äî a genuine
  ‚Ñö-subalgebra of `CohA`. Every cycle class is in it (`clA_mem_algebraicA`), and it is closed under the cup
  product (`mul_mem_algebraicA`, `tensor_mem_algebraicA`) ‚Äî *because it is a subalgebra*, not by fiat.

So the algebraic side of the Hodge picture is now **fully** concrete: the algebraic classes are the image
‚Ñö-subalgebra of a ‚Ñö-algebra homomorphism from the substrate's cycle ring, closed under cup product and
graded ‚Äî every structural property the Hodge conjecture asks of "the algebraic cycle classes."

**The honest open input (unchanged, never faked).** The conjecture is `hodge ‚â§ algebraic` for the **Hodge**
subspace defined by the *transcendental* `(p,p)` decomposition ‚Äî the analytic structure the substrate does
not yet synthesize. That single object is now the entire remaining gap; the algebraic half is complete. A
genuine rung ‚Äî the algebraic side finished ‚Äî **not** a proof of the conjecture. See `QLF_CohomologyLinear`,
`QLF_GradedCohomology`, `Hodge_QLF.md`.
-/

namespace QLF.CohomologyAlgebra

open QLF.CycleEncoding QLF.SpanningMap QLF.CohomologyRing

/-- The cohomology ring **as a ‚Ñö-algebra**: the monoid algebra on the cohomology monomials `Coh`
    (multiplication = convolution = cup product). -/
abbrev CohA : Type := AddMonoidAlgebra ‚Ñö Coh

/-- The cycle class map into the ‚Ñö-algebra: a cycle class to its cohomology monomial (coefficient 1). -/
noncomputable def clA (c : CycleClass) : CohA := Finsupp.single (cl c) 1

/-- **`cl` is multiplicative as a ring map**: the intersection product ‚Ü¶ the cup product (now honest
    ring multiplication, via `single_mul_single`). -/
theorem clA_mul (c d : CycleClass) : clA c * clA d = clA (c.tensor d) := by
  simp only [clA, AddMonoidAlgebra.single_mul_single, mul_one, cl_tensor, cup]

/-- **`cl` is unital as a ring map**: the unit cycle ‚Ü¶ the ring unit `1`. -/
theorem clA_one : clA unitCycle = 1 := by
  simp only [clA, cl_unit]
  rw [AddMonoidAlgebra.one_def]

/-- **The algebraic classes as a `Subalgebra ‚Ñö`** ‚Äî the ‚Ñö-subalgebra of cohomology generated by the cycle
    classes (the image subalgebra of the cycle class map). -/
noncomputable def algebraicA : Subalgebra ‚Ñö CohA := Algebra.adjoin ‚Ñö (Set.range clA)

/-- Every cycle class is algebraic. -/
theorem clA_mem_algebraicA (c : CycleClass) : clA c ‚àà algebraicA :=
  Algebra.subset_adjoin (Set.mem_range_self c)

/-- **The algebraic classes are closed under the cup product** ‚Äî because they form a subalgebra. -/
theorem mul_mem_algebraicA (c d : CycleClass) : clA c * clA d ‚àà algebraicA :=
  algebraicA.mul_mem (clA_mem_algebraicA c) (clA_mem_algebraicA d)

/-- The intersection-product class stays algebraic (the cup-closure read on the cycle ring). -/
theorem tensor_mem_algebraicA (c d : CycleClass) : clA (c.tensor d) ‚àà algebraicA := by
  rw [‚Üê clA_mul]
  exact mul_mem_algebraicA c d

/-- **Status ‚Äî the algebraic side of the Hodge picture is complete.** `cl` is a ‚Ñö-algebra homomorphism
    (`clA_mul`, `clA_one`) and the algebraic classes are a genuine `Subalgebra ‚Ñö` (`algebraicA`), closed
    under the cup product (`mul_mem_algebraicA`) ‚Äî every structural property the conjecture asks of the
    algebraic cycle classes, concrete and from the substrate's cycle ring. The lone remaining gap is the
    transcendental **Hodge** subspace (`hodge ‚â§ algebraic`, codim `p ‚â• 2`), the analytic input the substrate
    does not yet supply. The algebraic half finished ‚Äî **not** a proof of the conjecture. See
    `QLF_CohomologyLinear`, `Hodge_QLF.md`. -/
theorem cohomology_algebra_built : True := trivial

end QLF.CohomologyAlgebra
